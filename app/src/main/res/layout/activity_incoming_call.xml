<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- 来电图标 -->
    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="@string/incoming_call_icon_description"
        android:src="@android:drawable/ic_menu_camera"
        app:tint="@color/launcher_primary" />

    <!-- 来电提示文字 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/incoming_call_subtitle"
        android:textColor="@color/launcher_text_secondary"
        android:textSize="22sp" />

    <!-- 来电方姓名（大字） -->
    <TextView
        android:id="@+id/tv_incoming_caller"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="56dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:gravity="center"
        android:text="@string/incoming_call_unknown_caller"
        android:textColor="@color/launcher_primary_dark"
        android:textSize="48sp"
        android:textStyle="bold" />

    <!-- 按钮行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- 拒绝按钮 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_incoming_decline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/incoming_call_decline"
            app:cardBackgroundColor="@color/launcher_danger"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="20dp"
                android:text="@string/incoming_call_decline"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

        <!-- 接听按钮 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btn_incoming_accept"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/incoming_call_accept"
            app:cardBackgroundColor="@color/launcher_action"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="20dp"
                android:text="@string/incoming_call_accept"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</LinearLayout>
