<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="24dp"
    android:paddingEnd="20dp"
    android:paddingBottom="0dp"
    tools:context=".feature.home.MainActivity">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/launcher_surface"
        app:cardCornerRadius="28dp"
        app:cardElevation="6dp"
        app:strokeColor="@color/launcher_outline"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 时间日期区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="20dp"
                android:paddingEnd="24dp"
                android:paddingBottom="12dp">

                <TextView
                    android:id="@+id/tv_time"
                    style="@style/TextAppearance.OldLauncher.DisplayTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="56sp"
                    android:text="@string/home_time_placeholder" />

                <TextView
                    android:id="@+id/tv_date"
                    style="@style/TextAppearance.OldLauncher.Date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="17sp"
                    android:text="@string/home_date_placeholder" />

                <TextView
                    android:id="@+id/tv_lunar"
                    style="@style/TextAppearance.OldLauncher.Eyebrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="14sp"
                    android:text="" />

            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@color/launcher_outline" />

            <!-- 天气信息行 -->
            <LinearLayout
                android:id="@+id/layout_weather_entry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingTop="10dp"
                android:paddingEnd="24dp"
                android:paddingBottom="14dp">

                <!-- 左：城市 + 天气描述 + 高低温 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_weather_city"
                        style="@style/TextAppearance.OldLauncher.Eyebrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:text="北京" />

                    <TextView
                        android:id="@+id/tv_weather_desc"
                        style="@style/TextAppearance.OldLauncher.Date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textSize="17sp"
                        android:text="晴  北风 1-2级" />

                    <TextView
                        android:id="@+id/tv_weather_high_low"
                        style="@style/TextAppearance.OldLauncher.Eyebrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textSize="14sp"
                        android:text="最高 20°  最低 8°" />

                    <TextView
                        android:id="@+id/tv_weather_update"
                        style="@style/TextAppearance.OldLauncher.Eyebrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textSize="12sp"
                        android:alpha="0.6"
                        android:text="" />

                </LinearLayout>

                <!-- 右：当前温度 -->
                <TextView
                    android:id="@+id/tv_weather_temp"
                    style="@style/TextAppearance.OldLauncher.DisplayTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="48sp"
                    android:text="13°" />

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_home"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="20dp" />

</LinearLayout>
