<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.OldLauncher.DialogSurfaceCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/tv_dialog_title"
                style="@style/TextAppearance.OldLauncher.DialogTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/contact_dialog_add_title" />

            <TextView
                style="@style/TextAppearance.OldLauncher.DialogSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/label_photo" />

            <TextView
                style="@style/TextAppearance.OldLauncher.Meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/contact_dialog_avatar_tip" />

            <ImageView
                android:id="@+id/iv_photo_preview"
                android:layout_width="132dp"
                android:layout_height="132dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:background="@drawable/icon_background"
                android:contentDescription="@string/contact_photo_preview"
                android:padding="28dp"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_camera" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_select_photo"
                style="@style/Widget.OldLauncher.DialogButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <TextView
                    style="@style/TextAppearance.OldLauncher.ButtonPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:minHeight="54dp"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="14dp"
                    android:text="@string/action_select_photo" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                style="@style/TextAppearance.OldLauncher.DialogSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"
                android:text="@string/label_contact_name" />

            <EditText
                android:id="@+id/et_contact_name"
                style="@style/TextAppearance.OldLauncher.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="personName"
                android:background="@drawable/edit_text_background_focused"
                android:hint="@string/hint_wechat_contact_name"
                android:imeOptions="actionNext"
                android:inputType="textPersonName"
                android:maxLines="1"
                android:padding="18dp" />

            <TextView
                style="@style/TextAppearance.OldLauncher.Meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/contact_display_name_tip" />

            <TextView
                style="@style/TextAppearance.OldLauncher.DialogSectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"
                android:text="@string/label_wechat_search_name" />

            <EditText
                android:id="@+id/et_wechat_name"
                style="@style/TextAppearance.OldLauncher.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:autofillHints="nickname"
                android:background="@drawable/edit_text_background_focused"
                android:hint="@string/hint_wechat_search_name"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:maxLines="1"
                android:padding="18dp" />

            <TextView
                style="@style/TextAppearance.OldLauncher.Meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/contact_dialog_wechat_tip" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_cancel"
                    style="@style/Widget.OldLauncher.DialogButtonSecondary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1">

                    <TextView
                        style="@style/TextAppearance.OldLauncher.ButtonSecondary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:minHeight="54dp"
                        android:paddingStart="16dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="14dp"
                        android:text="@string/action_cancel" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_confirm"
                    style="@style/Widget.OldLauncher.DialogButtonPrimary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1">

                    <TextView
                        style="@style/TextAppearance.OldLauncher.ButtonPrimary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:minHeight="54dp"
                        android:paddingStart="16dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="14dp"
                        android:text="@string/action_confirm" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</com.google.android.material.card.MaterialCardView>
