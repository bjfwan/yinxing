<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_video_contact"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:layout_margin="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardBackgroundColor="@color/launcher_surface"
    app:cardCornerRadius="28dp"
    app:cardElevation="5dp"
    app:strokeColor="@color/launcher_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="18dp">

        <ImageView
            android:id="@+id/iv_video_contact_photo"
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:background="@drawable/icon_background"
            android:contentDescription="@string/contact_photo_preview"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/tv_video_contact_name"
            style="@style/TextAppearance.OldLauncher.CardTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="@string/video_contact_placeholder" />

        <TextView
            android:id="@+id/tv_video_contact_action"
            style="@style/TextAppearance.OldLauncher.HintStrong"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/contact_card_action_phone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
