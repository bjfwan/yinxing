<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_video_contact"
    style="@style/Widget.OldLauncher.ListItemCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="6dp"
    android:layout_marginTop="8dp"
    android:layout_marginEnd="6dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="188dp"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.1"
            android:paddingEnd="8dp">

            <ImageView
                android:id="@+id/iv_video_contact_photo"
                android:layout_width="152dp"
                android:layout_height="152dp"
                android:layout_gravity="center"
                android:background="@drawable/icon_background"
                android:contentDescription="@string/contact_photo_preview"
                android:scaleType="centerCrop" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.9"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <TextView
                android:id="@+id/tv_video_contact_name"
                style="@style/TextAppearance.OldLauncher.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@string/video_contact_placeholder" />

            <TextView
                android:id="@+id/tv_video_contact_action"
                style="@style/TextAppearance.OldLauncher.Badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/edit_text_background"
                android:gravity="center"
                android:maxLines="1"
                android:minHeight="40dp"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp"
                android:text="@string/contact_card_action_wechat_compact"
                android:textColor="@color/launcher_primary" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
