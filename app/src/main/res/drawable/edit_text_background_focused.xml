<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/launcher_surface" />
            <stroke
                android:width="2dp"
                android:color="@color/launcher_primary" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/launcher_surface_muted" />
            <stroke
                android:width="2dp"
                android:color="@color/launcher_outline" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
