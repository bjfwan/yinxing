# 复制本文件为 local.properties，填入你自己的配置
# local.properties 已在 .gitignore 中排除，不会提交到 Git

# Android SDK 路径
sdk.dir=D\:\\androidsdk

# Java 运行时由系统环境变量或根目录 build.bat 设置
# 当前本地 build.bat 使用 D:\Android\jbr

# 签名配置（Release 构建需要）
RELEASE_STORE_FILE=release-key.jks
RELEASE_KEY_ALIAS=mykey
RELEASE_STORE_PASSWORD=your_store_password_here
RELEASE_KEY_PASSWORD=your_key_password_here

# 心知天气 API（https://www.seniverse.com/）
# 注册后在控制台获取 UID 和私钥
SENIVERSE_UID=your_seniverse_uid_here
SENIVERSE_PK=your_seniverse_private_key_here

# 腾讯位置服务 API Key（https://lbs.qq.com/）
# 注册后在控制台创建应用并获取 Key
TENCENT_KEY=your_tencent_lbs_key_here

# AI 网关（可选，用于来电风险提醒与后续视频流程增强）
AI_GATEWAY_BASE_URL=https\://oldlauncher-ai.likeyou.qzz.io

# 本地代理（可选，按需填写）
# systemProp.http.proxyHost=127.0.0.1
# systemProp.http.proxyPort=7897
# systemProp.https.proxyHost=127.0.0.1
# systemProp.https.proxyPort=7897
